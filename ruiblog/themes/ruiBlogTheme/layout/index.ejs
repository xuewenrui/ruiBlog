<!-- 欢迎语 -->
<div class="welcome-message" style="text-align: center; margin-top: 20px;">
    <h2>欢迎来到 Rui 的博客！</h2>
    <p>这里记录了我对技术、生活和学习的点滴思考。希望你能在这里找到有价值的内容！</p>
</div>

<!-- 最新文章 -->
<div class="latest-posts" style="margin-top: 40px;">
    <h3>最新文章</h3>
    <ul style="list-style-type: none; padding-left: 0;">
        <% site.posts.sort((a, b) => new Date(b.date) - new Date(a.date)) // 按日期排序 %>
        <% const postsToShow = site.posts.slice(0, 5) // 只取前5篇最新文章 %>
        <% postsToShow.forEach(function(post) { %>
            <li style="margin-bottom: 20px;">
                <a href="<%= post.permalink %>" style="font-size: 1.2em; color: #007bff; text-decoration: none;">
                    <%= post.title %>
                </a>
                <p style="color: #555; font-size: 0.9em; margin-top: 5px;"><%= post.excerpt %></p>
            </li>
        <% }); %>
    </ul>
</div>

<!-- 文章分类 -->
<div class="categories" style="margin-top: 40px;">
    <h3>文章分类</h3>
    <ul>
        <li><a href="/category/技术">技术</a></li>
        <li><a href="/category/生活">生活</a></li>
        <li><a href="/category/学习">学习</a></li>
    </ul>
</div>

<!-- 搜索框 -->
<div class="search-bar" style="text-align: center; margin-top: 40px;">
    <input type="text" placeholder="搜索文章..." style="padding: 10px; width: 60%; border-radius: 5px;">
    <button style="padding: 10px 20px; margin-left: 10px; border-radius: 5px; background-color: #007bff; color: white;">搜索</button>
</div>

<!-- 个人简介 -->
<div class="about-me" style="margin-top: 40px; text-align: center;">
    <h3>关于我</h3>
    <p>我是 yuan rui，一个热衷于技术的学习者。我的博客记录了我对编程、技术、生活的思考。</p>
</div>
