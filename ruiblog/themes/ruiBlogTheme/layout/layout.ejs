<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title><%= config.title %></title>
    <link rel="stylesheet" href="/ruiBlog/css/custom.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
<!-- 引用 header.ejs -->
<%- partial('header') %>

<!-- 内容区域 -->
<div class="container" >
<!--    &lt;!&ndash; 侧边栏区域 &ndash;&gt;-->
    <div class="sidebars" style="flex-basis: 25%; display: flex; flex-direction: column; gap: 20px;">
        <% if (typeof page.sidebar1 === 'undefined' || page.sidebar1 === true) { %>
            <%- partial('sidebar1') %>
        <% } %>

        <% if (typeof page.sidebar2 === 'undefined' || page.sidebar2 === true) { %>
            <%- partial('sidebar2') %>
        <% } %>

        <% if (typeof page.sidebar3 === 'undefined' || page.sidebar3 === true) { %>
            <%- partial('sidebar3') %>
        <% } %>
    </div>

    <!-- 内容区域 -->
    <div class="content" style="flex-grow: 1; padding-left: 1%;">
        <%- body %>
    </div>
</div>

<!-- 引用 footer.ejs -->
<%- partial('footer') %>

</body>
</html>
